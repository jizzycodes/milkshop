PORT=4000
# Use localhost when you run the API or `node db/run-migration.js` on your machine.
# Use db only if the Node process runs inside Docker Compose (service name "db").
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_NAME=milkshop_backend
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=1h

# Franchise confirmation email (Gmail). Leave empty to skip sending.
# Use an App Password: https://support.google.com/accounts/answer/185833
GMAIL_USER=
GMAIL_APP_PASSWORD=
