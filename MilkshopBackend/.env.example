PORT=4000
# Use localhost when you run the API or `node db/run-migration.js` on your machine.
# Use db only if the Node process runs inside Docker Compose (service name "db").
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_NAME=milkshop_backend

# Firebase Admin (required for Firebase admin login)
# Firebase Console → Project settings → Service accounts → Generate new private key
FIREBASE_PROJECT_ID=milkshoplogin
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# Role for first-time Firebase sign-in when auto-creating user_accounts (admin or user)
FIREBASE_DEFAULT_ROLE=admin

# Email provider: auto (default), sendgrid, or smtp
# auto = SendGrid if SENDGRID_API_KEY is set, else SMTP (good for local + production)
EMAIL_PROVIDER=auto

# SendGrid (recommended for Linode — uses HTTPS port 443, not blocked SMTP ports)
# Sign up: https://sendgrid.com → verify sender → Settings → API Keys
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=milkshopph@hogia.co
SENDGRID_FROM_NAME=Milkshop Franchise

# SMTP (SpaceMail — works locally; Linode often blocks ports 465/587)
# File must live at MilkshopBackend/.env (backend reads this path, not repo root).
SMTP_HOST=mail.spacemail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=milkshopph@hogia.co
# Quote the password if it contains ! # or spaces: SMTP_PASSWORD="your-password"
SMTP_PASSWORD=
SMTP_FROM=milkshopph@hogia.co

# Logo in HTML emails (hosted URL — do not use huge inline images; Gmail clips ~102KB+)
EMAIL_LOGO_URL=https://milk-shop.ph/mlogo.webp

# Franchise confirmation SMS (Semaphore). Leave SEMAPHORE_API_KEY empty to skip.
# Docs: https://semaphore.co/docs
SEMAPHORE_API_KEY=
# Registered sender name in Semaphore dashboard (required if you have one set as default)
SEMAPHORE_SENDER_NAME=
# Optional custom SMS body; use (name) for the applicant's name
# SEMAPHORE_FRANCHISE_MESSAGE=Hi (name)! Thank you for your Milkshop franchise inquiry.
